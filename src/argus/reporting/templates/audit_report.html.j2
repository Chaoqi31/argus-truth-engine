<!doctype html>
<html><head><meta charset="utf-8"><title>Argus audit — {{ job.id }}</title></head>
<body>
  <section class="cover">
    <h1>Argus audit report</h1>
    <p class="meta">Job ID: {{ job.id }} · Generated {{ generated_at }}</p>
    {% if job.scenario_label %}<p class="meta"><strong>Scenario:</strong> {{ job.scenario_label }}</p>{% endif %}
    {% if job.persona %}<p class="meta"><strong>Audience:</strong> {{ job.persona }}</p>{% endif %}
    <h2>Executive summary</h2>
    <div>{{ executive_summary_html | safe }}</div>
    <h2>At a glance</h2>
    <ul>
      <li>Claims extracted: {{ job.claims | length }}</li>
      <li>Findings: {{ job.findings | length }}</li>
      <li>Evidences gathered: {{ job.evidences | length }}</li>
    </ul>
  </section>

  <h2>Findings</h2>
  {% for f in findings_ranked %}
  <div class="finding">
    <h3>{{ f.summary }}</h3>
    <div class="badges">
      <span class="badge b-{{ f.verdict }}">{{ f.verdict }}</span>
      <span class="badge b-{{ f.severity }}">{{ f.severity }}</span>
      <span class="badge">confidence {{ "%.2f" | format(f.confidence) }}</span>
      <span class="badge">{{ f.agent }}</span>
    </div>
    {% if evidence_by_finding.get(f.id) %}
    <div>
      <strong>Evidence</strong>
      {% for e in evidence_by_finding[f.id] %}
        <div class="evidence">
          {% if e.url %}<a href="{{ e.url }}">{{ e.url }}</a><br>{% endif %}
          {{ e.snippet or "" }}
        </div>
      {% endfor %}
    </div>
    {% endif %}
    {% if steps_by_finding.get(f.id) %}
    <div class="trace">{% for s in steps_by_finding[f.id] %}seq={{ s.sequence }} · {{ s.type }} → {{ s.summary }}
{% endfor %}</div>
    {% endif %}
  </div>
  {% endfor %}
</body></html>
