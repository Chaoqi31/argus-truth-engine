# Copy to .env and fill in your values. .env is gitignored.

# MiroMind
ARGUS_MIROMIND_API_KEY=sk-...
ARGUS_MIROMIND_MODEL=mirothinker-1-7-deepresearch

# Database — use the docker-compose default for local dev, or your own URL.
# For tests, this is overridden to sqlite+aiosqlite:///:memory: automatically.
ARGUS_DB_URL=postgresql+asyncpg://argus:argus@localhost:5436/argus
