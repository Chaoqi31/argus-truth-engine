# Copy to .env and fill in your values. .env is gitignored.

# MiroMind
ARGUS_MIROMIND_API_KEY=sk-...
ARGUS_MIROMIND_MODEL=mirothinker-1-7-deepresearch

# Database — use the docker-compose default for local dev, or your own URL.
# For tests, this is overridden to sqlite+aiosqlite:///:memory: automatically.
ARGUS_DB_URL=postgresql+asyncpg://argus:argus@localhost:5436/argus

# API server
ARGUS_API_HOST=127.0.0.1
ARGUS_API_PORT=8080
ARGUS_MAX_UPLOAD_BYTES=26214400
ARGUS_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional. When set, clients must send Authorization: Bearer <token>.
ARGUS_API_TOKEN=

# Trace bus — leave unset for in-process bus (recommended for single-instance).
# Set to redis://localhost:6390/0 to use Redis.
ARGUS_REDIS_URL=

# Where to store uploaded PDFs (created on first run).
ARGUS_STORAGE_ROOT=./uploads

# --- Concurrency & rate limiting (Phase 3 of arch improvements) ---
# Per-agent in-flight claim cap during Phase B verification.
ARGUS_UNIFIED_VERIFIER_CONCURRENCY=5
ARGUS_CONSISTENCY_CONCURRENCY=2
# Process-wide MiroMind request rate ceiling (req/s) and burst size.
ARGUS_MIROMIND_RPS=10.0
ARGUS_MIROMIND_RPS_BURST=20

# --- Result cache (Phase 4) ---
ARGUS_CACHE_ENABLED=true
ARGUS_CACHE_TTL_DAYS=30
ARGUS_CACHE_TTL_TIME_SENSITIVE_DAYS=3
